// 纯 GLSL 工具函数，由 effect 文件中各 CCProgram 通过 #include 引入。
// 此文件不含 precision / built-in include / #pragma —— 这些留在 CCProgram 壳中。

vec3 hsv2rgb(vec3 c) {
  vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
  vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
  return c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
}

// shapeBlend=0 → 圆形距离(L2)，shapeBlend=1 → 正方形距离(L∞)
float shapeDist(vec2 uv_c, float shapeBlend) {
  return mix(length(uv_c), max(abs(uv_c.x), abs(uv_c.y)), shapeBlend);
}
